# Frontend Environment Variables
# Copy this to .env.local and update values

# ============================================================
# DEVELOPMENT (Local)
# ============================================================
# For local development, backend runs on localhost:8000
# Leave this blank or comment out - next.config.js defaults to it
# BACKEND_URL=http://localhost:8000

# ============================================================
# PRODUCTION DEPLOYMENT
# ============================================================
# Set these when deploying:

# If using Hugging Face Spaces backend:
# BACKEND_URL=https://your-username-space-name.hf.space

# If using Railway backend:
# BACKEND_URL=https://your-railway-domain.up.railway.app

# If using custom domain:
# BACKEND_URL=https://api.yourdomain.com

# ============================================================
# HOW THIS WORKS
# ============================================================
# 
# Next.js next.config.js has rewrites that forward /api/* requests
# to the backend URL specified here.
# 
# This means:
# - Frontend code calls: fetch('/api/research', ...)
# - Next.js rewrites it to: fetch(BACKEND_URL + '/api/research', ...)
# - CORS issues are avoided (same-origin policy)
#
# Different deployment platforms:
# 
# LOCAL DEVELOPMENT:
#   npm run dev
#   - Frontend: http://localhost:3000
#   - Backend: http://localhost:8000
#   - BACKEND_URL not needed (defaults to localhost:8000)
#
# VERCEL + HF SPACES:
#   Set in Vercel Dashboard > Settings > Environment Variables:
#   BACKEND_URL=https://username-spacename.hf.space
#
# RAILWAY (all-in-one):
#   Both frontend and backend on Railway
#   Set BACKEND_URL to Railway backend domain
#
# ============================================================
