# ============================================================================
# ENVIRONMENT VARIABLES REFERENCE
# 
# Copy to .env and fill in your values
# Different platforms set some variables automatically
# ============================================================================

# -------- API KEYS (User provides these) --------
# Get Groq key (FREE): https://console.groq.com
GROQ_API_KEY=

# OpenAI API key (if using OpenAI models)
OPENAI_API_KEY=

# Tavily API key for web search (FREE tier available): https://tavily.com
TAVILY_API_KEY=

# Anthropic API key (if using Claude)
ANTHROPIC_API_KEY=

# Google API key (if using Gemini)
GOOGLE_API_KEY=

# -------- DEPLOYMENT CONFIGURATION --------
# Set to "production" for stricter CORS, "development" for broader CORS
ENVIRONMENT=development

# Additional allowed origins (comma-separated) for custom deployments
# Example: https://myapp.com,https://www.myapp.com
ALLOW_ORIGINS=

# -------- PLATFORM-SPECIFIC (Usually set automatically) --------
# Hugging Face Spaces: Sets PORT=7860 automatically
# Railway: Sets PORT=8000 automatically (or custom in settings)
# Other platforms: Will use PORT or default to 8000
PORT=

# ============================================================================
# QUICK DEPLOYMENT GUIDES
# ============================================================================
#
# HUGGING FACE SPACES (Recommended - Completely Free & Never Expires!):
# 1. Create Space at https://huggingface.co/spaces
# 2. Upload entire backend folder
# 3. Choose "Docker" SDK - it will auto-build from Dockerfile
# 4. HF Space gives you public URL (username-spacename.hf.space)
# 5. Set env vars in Space settings
#
# VERCEL (For Frontend):
# 1. Deploy frontend folder to Vercel (completely free)
# 2. Set NEXT_PUBLIC_API_URL=your-hf-space-url in Vercel settings
#
# RAILWAY (Free plan now limited, $5/month after):
# 1. Connect GitHub repo
# 2. Railway auto-detects Procfile
# 3. Set environment variables
#
# RENDER (Free with limitations):
# 1. Build: pip install -r requirements.txt
# 2. Start: uvicorn main:app --host 0.0.0.0 --port $PORT
# 3. Free tier sleeps after 15 min of inactivity
#
# ============================================================================